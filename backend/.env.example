# =============================================================================
# R2V backend environment template
# -----------------------------------------------------------------------------
# Copy to .env for LOCAL docker-compose development:  copy .env.example .env
# The values below are the LOCAL DEV defaults (docker-compose service names).
#
# For AWS production, DO NOT use this file as-is. Set the same KEYS as ECS task
# environment variables / Secrets Manager values, using the "AWS production"
# guidance shown under each section. Never bake real secrets into an image or
# commit a populated .env.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE  (PostgreSQL)
# -----------------------------------------------------------------------------
# Local dev (docker-compose service "db"):
DATABASE_URL=postgresql+psycopg://r2v:r2v@db:5432/r2v
# AWS production (RDS):  keep the psycopg driver, point at the RDS endpoint:
#   DATABASE_URL=postgresql+psycopg://<user>:<password>@<rds-endpoint>:5432/r2v
#   (append ?sslmode=require to enforce TLS to RDS)


# -----------------------------------------------------------------------------
# REDIS  (Celery broker + cache)
# -----------------------------------------------------------------------------
# Local dev (docker-compose service "redis"):
REDIS_URL=redis://redis:6379/0
# AWS production (ElastiCache for Redis/Valkey):
#   REDIS_URL=redis://<elasticache-primary-endpoint>:6379/0
#   With in-transit encryption enabled use the rediss:// scheme:
#   REDIS_URL=rediss://<elasticache-primary-endpoint>:6379/0


# -----------------------------------------------------------------------------
# LOCAL DEV ONLY — host port mapping for the API container
# -----------------------------------------------------------------------------
# The container always listens on :8000. This only changes the published host
# port for docker-compose. Not used on ECS (the task port is 8000).
API_PORT=18001


# -----------------------------------------------------------------------------
# S3 / OBJECT STORAGE
# -----------------------------------------------------------------------------
# Local dev = MinIO. AWS production = real S3.
#
# S3_ENDPOINT_URL:
#   Local dev (MinIO):   http://minio:9000
#   AWS production:      LEAVE EMPTY  -> boto3 uses the real regional S3 endpoint.
# S3_PUBLIC_ENDPOINT_URL (host browsers/clients use to reach presigned URLs):
#   Local dev (MinIO):   http://localhost:9000
#   AWS production:      LEAVE EMPTY  -> presigned URLs use the real S3 host.
# S3_ACCESS_KEY / S3_SECRET_KEY:
#   Local dev (MinIO):   minioadmin / minioadmin
#   AWS production:      LEAVE BOTH EMPTY -> boto3 uses the ECS IAM task role.
#                        (Do NOT hardcode AWS access keys.)
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Bucket names (must exist; create them in S3 for production).
S3_BUCKET_MARKETPLACE_MODELS=r2v-marketplace-models
S3_BUCKET_MARKETPLACE_THUMBS=r2v-marketplace-thumbs
S3_BUCKET_SCANS_RAW=r2v-user-scans-raw
S3_BUCKET_JOB_OUTPUTS=r2v-job-outputs
S3_BUCKET_CHAT_ATTACHMENTS=r2v-chat-attachments


# -----------------------------------------------------------------------------
# JWT / SECURITY
# -----------------------------------------------------------------------------
# AWS production: set JWT_SECRET to a long random value from Secrets Manager.
JWT_SECRET=dev_secret_change_in_prod
JWT_ISSUER=r2v-backend
JWT_AUDIENCE=r2v-client
ACCESS_TOKEN_EXPIRES_MIN=30
REFRESH_TOKEN_EXPIRES_DAYS=30
VERIFICATION_CODE_EXPIRES_MIN=15
PASSWORD_RESET_EXPIRES_MIN=30

# ----- Email verification + SMTP --------------------------------------------
# REQUIRE_EMAIL_VERIFICATION=true  -> accounts must confirm an emailed code
#   before login (needs EMAIL_ENABLED=true + working SMTP, otherwise the code is
#   only visible as dev_code when ENV=dev).
# REQUIRE_EMAIL_VERIFICATION=false -> signup/login enter the app directly.
REQUIRE_EMAIL_VERIFICATION=true
# Master switch for outbound email. In local dev this is usually false: the code
# is returned as dev_code (ENV=dev) instead of being emailed.
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@localhost
SMTP_FROM_NAME=RealTwoVirtual
SMTP_USE_TLS=true


# -----------------------------------------------------------------------------
# CORS / ENV
# -----------------------------------------------------------------------------
# Local dev: the Flutter web dev server origin.
# AWS production: set to your CloudFront / custom frontend domain, e.g.
#   ALLOWED_ORIGINS=https://app.example.com
#   ALLOWED_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?example\.com$
ALLOWED_ORIGINS=http://localhost:55509
ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
# Set ENV=production in AWS (drives is_production behaviour).
ENV=dev
LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# OAUTH (optional — leave empty if unused)
# -----------------------------------------------------------------------------
# GOOGLE — "Continue with Google" / verified login.
#
# Create a Web application OAuth client in Google Cloud Console
# (APIs & Services -> Credentials -> Create credentials -> OAuth client ID):
#   Authorized JavaScript origins  -> your FRONTEND url, e.g.
#       http://localhost:55509
#       https://app.example.com
#   Authorized redirect URIs       -> your BACKEND callback, e.g.
#       http://localhost:8000/auth/oauth/google/callback
#       https://YOUR_API_DOMAIN/auth/oauth/google/callback
# Then copy the client id/secret here. The backend verifies the Google ID token
# (signature, audience, issuer, expiry) AND requires email_verified=true before
# logging the user in. Never trust an email sent from the frontend.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Frontend route that finishes the OAuth redirect (receives R2V tokens). The
# Flutter web app passes this per-request as redirect_uri; set it here for
# documentation / non-web clients. Example:
#   FRONTEND_OAUTH_CALLBACK_URL=http://localhost:55509/#/oauth/callback
FRONTEND_OAUTH_CALLBACK_URL=
APPLE_OAUTH_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# STRIPE  (optional — leave empty if billing is not enabled)
# -----------------------------------------------------------------------------
# AWS production: put the live keys in Secrets Manager and point the URLs at the
# deployed frontend, e.g. https://app.example.com/#/billing/success
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:55509/#/billing/success
STRIPE_CANCEL_URL=http://localhost:55509/#/billing/cancel
STRIPE_SUBSCRIPTION_PRICE_ID=


# -----------------------------------------------------------------------------
# SUPER ADMIN BOOTSTRAP (the only way to mint the first super_admin)
# -----------------------------------------------------------------------------
# On startup the account is created (if missing) or promoted to super_admin.
# The password is only used when creating a new account.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_USERNAME=
SUPER_ADMIN_PASSWORD=


# -----------------------------------------------------------------------------
# RATE LIMITING / UPLOAD LIMITS
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
MAX_UPLOAD_BYTES=104857600


# -----------------------------------------------------------------------------
# MODAL AI  (prompt / image -> 3D)
# -----------------------------------------------------------------------------
# Async job contract:
#   POST /generate or /image-to-3d -> { job_id } -> poll GET /jobs/{job_id}
#   -> download glb_url / files.final_glb when status == "succeeded".
# MODAL_R2V_ENDPOINT_URL takes precedence over MODAL_API_URL. At least one MUST
# be set (same value in dev and prod) or AI jobs fail with a clear
# "endpoint not configured" error.
MODAL_R2V_ENDPOINT_URL=https://ma1260781--r2v-sd-hunyuan3d-api.modal.run
MODAL_API_URL=https://ma1260781--r2v-sd-hunyuan3d-api.modal.run
MODAL_IMAGE_TO_3D_PATH=/image-to-3d
MODAL_PROMPT_TO_3D_PATH=/generate
# Optional: only set if the Modal app enforces a bearer token (R2V_API_TOKEN).
R2V_API_TOKEN=
MODAL_DEFAULT_WITH_TEXTURE=true
MODAL_API_TIMEOUT_S=900
MODAL_DOWNLOAD_RETRY_S=5
MODAL_DOWNLOAD_MAX_ATTEMPTS=30
MODAL_DOWNLOAD_FALLBACK_MAX_ATTEMPTS=6
MODAL_POLL_TIMEOUT_S=1800
MODAL_POLL_INTERVAL_S=5


# -----------------------------------------------------------------------------
# PHOTOGRAMMETRY  (photos -> 3D, served by the deployed Modal app)
# -----------------------------------------------------------------------------
# The backend is now a proxy/controller: it forwards reconstruction jobs to the
# Modal photogrammetry app and caches the returned outputs locally. It no longer
# runs COLMAP/OpenMVS/Blender, so no local tools/binaries are required.
#
# Modal contract:  POST /reconstruct (multipart: files[], texture_mode,
# no_strict_mask) -> BLOCKING; returns a ZIP of all outputs. Same value in dev
# and prod.
PHOTOGRAMMETRY_PROVIDER=modal
PHOTOGRAMMETRY_MODAL_API_URL=https://seifh3333--r2v-photogrammetry-pipeline-fastapi-app.modal.run
# Max time (seconds) to wait for the blocking Modal reconstruction (30 min).
PHOTOGRAMMETRY_MODAL_TIMEOUT_S=1800
# Lifetime (seconds) of the signed token embedded in download URLs (6h).
PHOTOGRAMMETRY_DOWNLOAD_TOKEN_EXPIRES_S=21600

# Local cache root for per-job outputs returned by Modal (mounted volume).
PHOTOGRAMMETRY_JOBS_ROOT=jobs
# Forwarded to Modal as reconstruction options + local upload validation.
PHOTOGRAMMETRY_TEXTURE_MODE=vertexcolor
PHOTOGRAMMETRY_NO_STRICT_MASK=false
PHOTOGRAMMETRY_MIN_IMAGES=3
PHOTOGRAMMETRY_MAX_IMAGES=250
PHOTOGRAMMETRY_MAX_IMAGE_BYTES=26214400
