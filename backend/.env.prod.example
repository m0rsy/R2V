# =============================================================================
# R2V PRODUCTION env template  (AWS EC2 + Docker Compose + Caddy + MinIO)
# -----------------------------------------------------------------------------
# Copy to .env on the SERVER and fill the CHANGE_ME values:
#   cp .env.prod.example .env
# NEVER commit the filled .env. NEVER put real secrets in this example file.
#
# This profile runs Postgres + Redis + MinIO as containers on the SAME EC2 box
# (free-tier friendly). For managed AWS services (RDS/ElastiCache/S3) see the
# AWS notes in .env.example instead.
# =============================================================================

# ----- Core environment -----------------------------------------------------
ENV=prod
LOG_LEVEL=INFO

# ----- Database (Postgres container) ----------------------------------------
# The db container reads POSTGRES_* below; the app reads DATABASE_URL. The
# password MUST be identical in both places. Generate: openssl rand -hex 24
POSTGRES_USER=r2v
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=r2v
DATABASE_URL=postgresql+psycopg://r2v:CHANGE_ME_db_password@db:5432/r2v

# ----- Redis (container) ----------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ----- JWT / security -------------------------------------------------------
# Generate with:  openssl rand -hex 48
JWT_SECRET=CHANGE_ME_long_random_secret
JWT_ISSUER=r2v-backend
JWT_AUDIENCE=r2v-client
ACCESS_TOKEN_EXPIRES_MIN=30
REFRESH_TOKEN_EXPIRES_DAYS=30
VERIFICATION_CODE_EXPIRES_MIN=15
PASSWORD_RESET_EXPIRES_MIN=30

# ----- Email verification + SMTP --------------------------------------------
# REQUIRE_EMAIL_VERIFICATION=true  -> new accounts must confirm an emailed code
#   before they can log in. EMAIL_ENABLED must be true (with working SMTP) or
#   users will never receive the code.
# REQUIRE_EMAIL_VERIFICATION=false -> signup/login enter the app directly (safe
#   temporary bypass for testing). No code is sent.
REQUIRE_EMAIL_VERIFICATION=true
# Master switch for outbound email. false = codes are created but never sent.
EMAIL_ENABLED=false
# SMTP transport (e.g. Gmail uses an App Password, NOT your normal password).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@realtwovirtual.com
SMTP_FROM_NAME=RealTwoVirtual
SMTP_USE_TLS=true

# ----- CORS (production frontend origins) -----------------------------------
ALLOWED_ORIGINS=https://realtwovirtual.com,https://www.realtwovirtual.com
ALLOWED_ORIGIN_REGEX=^https://(www\.)?realtwovirtual\.com$

# ----- S3 / object storage (MinIO behind Caddy at files.realtwovirtual.com) -
# Internal endpoint the api/worker containers use to reach MinIO:
S3_ENDPOINT_URL=http://minio:9000
# Public endpoint embedded in presigned URLs handed to browsers:
S3_PUBLIC_ENDPOINT_URL=https://files.realtwovirtual.com
# MinIO root credentials. These are BOTH the MinIO admin creds AND the keys the
# app signs with — use strong values (generate: openssl rand -hex 20).
S3_ACCESS_KEY=CHANGE_ME_minio_access_key
S3_SECRET_KEY=CHANGE_ME_minio_secret_key
S3_REGION=us-east-1
S3_BUCKET_MARKETPLACE_MODELS=r2v-marketplace-models
S3_BUCKET_MARKETPLACE_THUMBS=r2v-marketplace-thumbs
S3_BUCKET_SCANS_RAW=r2v-user-scans-raw
S3_BUCKET_JOB_OUTPUTS=r2v-job-outputs
S3_BUCKET_CHAT_ATTACHMENTS=r2v-chat-attachments

# ----- Modal AI (prompt / image -> 3D) --------------------------------------
# At least one of the two endpoint vars MUST be set (same value as dev).
MODAL_R2V_ENDPOINT_URL=https://ma1260781--r2v-sd-hunyuan3d-api.modal.run
MODAL_API_URL=https://ma1260781--r2v-sd-hunyuan3d-api.modal.run
MODAL_IMAGE_TO_3D_PATH=/image-to-3d
MODAL_PROMPT_TO_3D_PATH=/generate
# Only set if the Modal app enforces a bearer token:
R2V_API_TOKEN=
MODAL_DEFAULT_WITH_TEXTURE=true
MODAL_API_TIMEOUT_S=900
MODAL_POLL_TIMEOUT_S=1800
MODAL_POLL_INTERVAL_S=5

# ----- Photogrammetry (photos -> 3D, served by Modal) -----------------------
PHOTOGRAMMETRY_PROVIDER=modal
PHOTOGRAMMETRY_MODAL_API_URL=https://seifh3333--r2v-photogrammetry-pipeline-fastapi-app.modal.run
PHOTOGRAMMETRY_MODAL_TIMEOUT_S=1800
PHOTOGRAMMETRY_DOWNLOAD_TOKEN_EXPIRES_S=21600

# ----- Stripe (optional — leave keys empty if billing is off) ---------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUBSCRIPTION_PRICE_ID=
STRIPE_SUCCESS_URL=https://realtwovirtual.com/#/billing/success
STRIPE_CANCEL_URL=https://realtwovirtual.com/#/billing/cancel

# ----- Google OAuth (optional — leave empty if unused) ----------------------
# Authorized JavaScript origin:  https://realtwovirtual.com
# Authorized redirect URI:       https://api.realtwovirtual.com/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FRONTEND_OAUTH_CALLBACK_URL=https://realtwovirtual.com/#/oauth/callback

# ----- Super admin bootstrap (creates/promotes first super_admin on startup)-
SUPER_ADMIN_EMAIL=CHANGE_ME_admin@realtwovirtual.com
SUPER_ADMIN_USERNAME=CHANGE_ME_admin
SUPER_ADMIN_PASSWORD=CHANGE_ME_strong_password

# ----- Rate limiting / upload limits ----------------------------------------
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
MAX_UPLOAD_BYTES=104857600
